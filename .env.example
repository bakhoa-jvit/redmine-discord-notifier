REDMINE_BASE_URL=https://redmine.example.com
REDMINE_API_KEY=replace_with_your_personal_api_key

# One-time import source: on first boot, if the `projects` table in SQLite
# is empty and this file exists, its contents are imported into the DB and
# the file is never read again. Manage projects and assignee mappings
# through the admin UI afterwards.
PROJECTS_CONFIG_FILE=./config/projects.json

POLL_INTERVAL_SECONDS=60
POLL_OVERLAP_SECONDS=120
REDMINE_PAGE_LIMIT=100
MAX_ISSUE_DETAIL_REQUESTS_PER_CYCLE=200
SKIP_MISSED_ON_START=true
SQLITE_PATH=./data/notifier.sqlite
STARTUP_MODE=baseline
LOG_LEVEL=info

# Admin web UI
ADMIN_PORT=3000
ADMIN_SESSION_SECRET=replace_with_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password
